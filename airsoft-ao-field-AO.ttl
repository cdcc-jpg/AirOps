@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <http://schema.org/> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix asoft: <https://github.com/cdcc-jpg/ontologies#> .
@base <https://github.com/cdcc-jpg/ontologies/field-ao> .

<https://github.com/cdcc-jpg/ontologies/field-ao> rdf:type owl:Ontology ;
    dcterms:title "Airsoft Field Application Ontology" ;
    dcterms:creator "clement.dhollande@leurn.co" ;
    dcterms:created "2026-05-17"^^xsd:date ;
    dcterms:description "An application ontology focusing on airsoft field design, zones, safety, and environmental constraints for indoor and outdoor play." ;
    owl:versionInfo "1.0" ;
    owl:imports <https://github.com/cdcc-jpg/ontologies> .

#################################################################
#    Classes
#################################################################

###  https://github.com/cdcc-jpg/ontologies#FieldEnvironment
asoft:FieldEnvironment rdf:type owl:Class ;
    rdfs:label "Field Environment"@en ;
    rdfs:comment "A conceptual container for all field-specific structures, constraints, and environmental conditions."@en .

###  https://github.com/cdcc-jpg/ontologies#FieldZone
asoft:FieldZone rdf:type owl:Class ;
    rdfs:label "Field zone"@en ;
    rdfs:comment "A distinct operational area within an airsoft field, such as a spawn, objective, or spectator zone."@en ;
    rdfs:subClassOf schema:Place .

###  https://github.com/cdcc-jpg/ontologies#FieldSurface
asoft:FieldSurface rdf:type owl:Class ;
    rdfs:label "Field surface"@en ;
    rdfs:comment "The ground or floor material used by an airsoft field."@en .

###  https://github.com/cdcc-jpg/ontologies#FieldObstacle
asoft:FieldObstacle rdf:type owl:Class ;
    rdfs:label "Field obstacle"@en ;
    rdfs:comment "A static or semi-static structure used as cover, barrier, or tactical challenge in the field."@en .

###  https://github.com/cdcc-jpg/ontologies#SafetyZone
asoft:SafetyZone rdf:type owl:Class ;
    rdfs:label "Safety zone"@en ;
    rdfs:comment "A non-combat area where players may remove protective equipment, rest, or receive instructions."@en ;
    rdfs:subClassOf asoft:FieldZone .

###  https://github.com/cdcc-jpg/ontologies#SpawnArea
asoft:SpawnArea rdf:type owl:Class ;
    rdfs:label "Spawn area"@en ;
    rdfs:comment "A dedicated area where players enter the field before the game starts."@en ;
    rdfs:subClassOf asoft:FieldZone .

###  https://github.com/cdcc-jpg/ontologies#ObjectiveArea
asoft:ObjectiveArea rdf:type owl:Class ;
    rdfs:label "Objective area"@en ;
    rdfs:comment "A target or mission area where game objectives are located."@en ;
    rdfs:subClassOf asoft:FieldZone .

###  https://github.com/cdcc-jpg/ontologies#SpectatorArea
asoft:SpectatorArea rdf:type owl:Class ;
    rdfs:label "Spectator area"@en ;
    rdfs:comment "A zone reserved for non-participants to watch play safely."@en ;
    rdfs:subClassOf asoft:FieldZone .

###  https://github.com/cdcc-jpg/ontologies#RestrictedArea
asoft:RestrictedArea rdf:type owl:Class ;
    rdfs:label "Restricted area"@en ;
    rdfs:comment "A field section that is off-limits during play due to safety, administration, or environmental restrictions."@en ;
    rdfs:subClassOf asoft:FieldZone .

###  https://github.com/cdcc-jpg/ontologies#EntryPoint
asoft:EntryPoint rdf:type owl:Class ;
    rdfs:label "Entry point"@en ;
    rdfs:comment "A controlled access location onto the field."@en ;
    rdfs:subClassOf schema:Place .

###  https://github.com/cdcc-jpg/ontologies#LightingCondition
asoft:LightingCondition rdf:type owl:Class ;
    rdfs:label "Lighting condition"@en ;
    rdfs:comment "A specification of the illumination level for the field or a field zone."@en .

###  https://github.com/cdcc-jpg/ontologies#VentilationCondition
asoft:VentilationCondition rdf:type owl:Class ;
    rdfs:label "Ventilation condition"@en ;
    rdfs:comment "A description of the air circulation or climate control for an indoor field."@en .

###  https://github.com/cdcc-jpg/ontologies#WeatherExposure
asoft:WeatherExposure rdf:type owl:Class ;
    rdfs:label "Weather exposure"@en ;
    rdfs:comment "The degree to which an outdoor field is exposed to weather and environmental conditions."@en .

#################################################################
#    Object Properties
#################################################################

###  https://github.com/cdcc-jpg/ontologies#hasFieldZone
asoft:hasFieldZone rdf:type owl:ObjectProperty ;
    rdfs:label "has field zone"@en ;
    rdfs:comment "Connects a field to one of its operational zones."@en ;
    rdfs:domain asoft:AirsoftField ;
    rdfs:range asoft:FieldZone .

###  https://github.com/cdcc-jpg/ontologies#hasSurfaceType
asoft:hasSurfaceType rdf:type owl:ObjectProperty ;
    rdfs:label "has surface type"@en ;
    rdfs:comment "Links a field to its surface material definition."@en ;
    rdfs:domain asoft:AirsoftField ;
    rdfs:range asoft:FieldSurface .

###  https://github.com/cdcc-jpg/ontologies#hasObstacle
asoft:hasObstacle rdf:type owl:ObjectProperty ;
    rdfs:label "has obstacle"@en ;
    rdfs:comment "Links a zone to an obstacle present within that zone."@en ;
    rdfs:domain asoft:FieldZone ;
    rdfs:range asoft:FieldObstacle .

###  https://github.com/cdcc-jpg/ontologies#hasSafetyZone
asoft:hasSafetyZone rdf:type owl:ObjectProperty ;
    rdfs:label "has safety zone"@en ;
    rdfs:comment "Indicates that the field provides a defined safety area."@en ;
    rdfs:domain asoft:AirsoftField ;
    rdfs:range asoft:SafetyZone .

###  https://github.com/cdcc-jpg/ontologies#hasEntryPoint
asoft:hasEntryPoint rdf:type owl:ObjectProperty ;
    rdfs:label "has entry point"@en ;
    rdfs:comment "Identifies an access point to the field."@en ;
    rdfs:domain asoft:AirsoftField ;
    rdfs:range asoft:EntryPoint .

###  https://github.com/cdcc-jpg/ontologies#hasLightingCondition
asoft:hasLightingCondition rdf:type owl:ObjectProperty ;
    rdfs:label "has lighting condition"@en ;
    rdfs:comment "Specifies the lighting conditions used in the field or zone."@en ;
    rdfs:domain asoft:AirsoftField ;
    rdfs:range asoft:LightingCondition .

###  https://github.com/cdcc-jpg/ontologies#hasVentilationCondition
asoft:hasVentilationCondition rdf:type owl:ObjectProperty ;
    rdfs:label "has ventilation condition"@en ;
    rdfs:comment "Connects an indoor field to its ventilation or climate control characteristics."@en ;
    rdfs:domain asoft:AirsoftField ;
    rdfs:range asoft:VentilationCondition .

###  https://github.com/cdcc-jpg/ontologies#hasWeatherExposure
asoft:hasWeatherExposure rdf:type owl:ObjectProperty ;
    rdfs:label "has weather exposure"@en ;
    rdfs:comment "Describes an outdoor field's exposure profile to wind, rain, sun, and temperature."@en ;
    rdfs:domain asoft:AirsoftField ;
    rdfs:range asoft:WeatherExposure .

###  https://github.com/cdcc-jpg/ontologies#isAdjacentTo
asoft:isAdjacentTo rdf:type owl:ObjectProperty ;
    rdfs:label "is adjacent to"@en ;
    rdfs:comment "Relates field zones that share a boundary or are adjacent in the layout."@en ;
    rdfs:domain asoft:FieldZone ;
    rdfs:range asoft:FieldZone ;
    owl:inverseOf asoft:isAdjacentTo .

###  https://github.com/cdcc-jpg/ontologies#requiresSafetyApproval
asoft:requiresSafetyApproval rdf:type owl:ObjectProperty ;
    rdfs:label "requires safety approval"@en ;
    rdfs:comment "Indicates that an airsoft field must meet a safety rule before it may be used."@en ;
    rdfs:domain asoft:AirsoftField ;
    rdfs:range asoft:AirsoftRule .

#################################################################
#    Data Properties
#################################################################

###  https://github.com/cdcc-jpg/ontologies#hasMaximumCapacity
asoft:hasMaximumCapacity rdf:type owl:DatatypeProperty ;
    rdfs:label "has maximum capacity"@en ;
    rdfs:comment "The maximum number of participants allowed on the field at one time."@en ;
    rdfs:domain asoft:AirsoftField ;
    rdfs:range xsd:integer .

###  https://github.com/cdcc-jpg/ontologies#hasSurfaceMaterial
asoft:hasSurfaceMaterial rdf:type owl:DatatypeProperty ;
    rdfs:label "has surface material"@en ;
    rdfs:comment "A textual description of the field surface material."@en ;
    rdfs:domain asoft:AirsoftField ;
    rdfs:range xsd:string .

###  https://github.com/cdcc-jpg/ontologies#hasDimension
asoft:hasDimension rdf:type owl:DatatypeProperty ;
    rdfs:label "has dimension"@en ;
    rdfs:comment "The approximate field dimensions or footprint."@en ;
    rdfs:domain asoft:AirsoftField ;
    rdfs:range xsd:string .

###  https://github.com/cdcc-jpg/ontologies#hasLightingLevel
asoft:hasLightingLevel rdf:type owl:DatatypeProperty ;
    rdfs:label "has lighting level"@en ;
    rdfs:comment "A descriptive level for the field's illumination, such as bright, low, or dynamic."@en ;
    rdfs:domain asoft:AirsoftField ;
    rdfs:range xsd:string .

###  https://github.com/cdcc-jpg/ontologies#hasVentilationRating
asoft:hasVentilationRating rdf:type owl:DatatypeProperty ;
    rdfs:label "has ventilation rating"@en ;
    rdfs:comment "A qualitative rating of airflow, climate control, or ventilation efficiency."@en ;
    rdfs:domain asoft:AirsoftField ;
    rdfs:range xsd:string .

###  https://github.com/cdcc-jpg/ontologies#hasWeatherCondition
asoft:hasWeatherCondition rdf:type owl:DatatypeProperty ;
    rdfs:label "has weather condition"@en ;
    rdfs:comment "A short description of the current or typical outdoor weather conditions."@en ;
    rdfs:domain asoft:OutdoorAirsoftField ;
    rdfs:range xsd:string .

###  https://github.com/cdcc-jpg/ontologies#hasMinimumSafeDistance
asoft:hasMinimumSafeDistance rdf:type owl:DatatypeProperty ;
    rdfs:label "has minimum safe distance"@en ;
    rdfs:comment "Minimum separation distance required between field elements or play areas."@en ;
    rdfs:domain asoft:AirsoftField ;
    rdfs:range xsd:decimal .

###  https://github.com/cdcc-jpg/ontologies#hasAccessRestriction
asoft:hasAccessRestriction rdf:type owl:DatatypeProperty ;
    rdfs:label "has access restriction"@en ;
    rdfs:comment "Describes the required permissions or limitations for entering the field."@en ;
    rdfs:domain asoft:AirsoftField ;
    rdfs:range xsd:string .

#################################################################
#    Field Instances
#################################################################

###  https://github.com/cdcc-jpg/ontologies#IndoorCQBField
asoft:IndoorCQBField rdf:type owl:NamedIndividual, asoft:IndoorAirsoftField ;
    rdfs:label "CQB Indoor Field"@en ;
    rdfs:comment "A close-quarters combat indoor airsoft field with dense obstacles and controlled climate."@en ;
    asoft:hasSurfaceMaterial "Concrete and reclaimed wood" ;
    asoft:hasDimension "40m x 30m" ;
    asoft:hasMaximumCapacity 40 ;
    asoft:hasLightingLevel "Bright" ;
    asoft:hasVentilationRating "High" ;
    asoft:hasMinimumSafeDistance 5.0 ;
    asoft:hasAccessRestriction "Authorized players and referees only" ;
    asoft:hasFieldZone asoft:SpawnZone_IndoorCQB , asoft:ObjectiveZone_IndoorCQB , asoft:SpectatorArea_IndoorCQB ;
    asoft:hasEntryPoint asoft:Entry_IndoorCQB ;
    asoft:hasSafetyZone asoft:SafetyZone_IndoorCQB ;
    asoft:requiresSafetyApproval asoft:PowerLimit , asoft:Kill .

###  https://github.com/cdcc-jpg/ontologies#OutdoorWoodsField
asoft:OutdoorWoodsField rdf:type owl:NamedIndividual, asoft:OutdoorAirsoftField ;
    rdfs:label "Outdoor Woods Field"@en ;
    rdfs:comment "A natural outdoor forest-style airsoft field with variable terrain and weather exposure."@en ;
    asoft:hasSurfaceMaterial "Grass, soil, gravel" ;
    asoft:hasDimension "150m x 120m" ;
    asoft:hasMaximumCapacity 80 ;
    asoft:hasLightingLevel "Natural daylight" ;
    asoft:hasWeatherExposure "Open to sun, wind, and rain" ;
    asoft:hasMinimumSafeDistance 10.0 ;
    asoft:hasAccessRestriction "Registered players only" ;
    asoft:hasFieldZone asoft:SpawnZone_OutdoorWoods , asoft:ObjectiveZone_OutdoorWoods , asoft:RestrictedArea_OutdoorWoods ;
    asoft:hasEntryPoint asoft:Entry_OutdoorWoods ;
    asoft:hasSafetyZone asoft:SafetyZone_OutdoorWoods ;
    asoft:requiresSafetyApproval asoft:NoiseLimit , asoft:PowerLimit .

#################################################################
#    Field Zones and Components
#################################################################

###  https://github.com/cdcc-jpg/ontologies#SpawnZone_IndoorCQB
asoft:SpawnZone_IndoorCQB rdf:type owl:NamedIndividual, asoft:SpawnArea ;
    rdfs:label "Indoor CQB Spawn"@en ;
    asoft:hasObstacle asoft:Cover_Wall , asoft:Cover_Barrel ;
    asoft:isAdjacentTo asoft:ObjectiveZone_IndoorCQB .

###  https://github.com/cdcc-jpg/ontologies#ObjectiveZone_IndoorCQB
asoft:ObjectiveZone_IndoorCQB rdf:type owl:NamedIndividual, asoft:ObjectiveArea ;
    rdfs:label "Indoor CQB Objective"@en ;
    asoft:hasObstacle asoft:Cover_Pillar ;
    asoft:isAdjacentTo asoft:SpawnZone_IndoorCQB , asoft:SpectatorArea_IndoorCQB .

###  https://github.com/cdcc-jpg/ontologies#SpectatorArea_IndoorCQB
asoft:SpectatorArea_IndoorCQB rdf:type owl:NamedIndividual, asoft:SpectatorArea ;
    rdfs:label "Indoor CQB Spectator Area"@en ;
    asoft:isAdjacentTo asoft:ObjectiveZone_IndoorCQB .

###  https://github.com/cdcc-jpg/ontologies#SafetyZone_IndoorCQB
asoft:SafetyZone_IndoorCQB rdf:type owl:NamedIndividual, asoft:SafetyZone ;
    rdfs:label "Indoor CQB Safety Zone"@en ;
    asoft:hasAccessRestriction "No airsoft weapons allowed" .

###  https://github.com/cdcc-jpg/ontologies#Entry_IndoorCQB
asoft:Entry_IndoorCQB rdf:type owl:NamedIndividual, asoft:EntryPoint ;
    rdfs:label "Indoor CQB Entry"@en ;
    asoft:hasAccessRestriction "Staff-controlled entrance" .

###  https://github.com/cdcc-jpg/ontologies#SpawnZone_OutdoorWoods
asoft:SpawnZone_OutdoorWoods rdf:type owl:NamedIndividual, asoft:SpawnArea ;
    rdfs:label "Outdoor Woods Spawn"@en ;
    asoft:hasObstacle asoft:Cover_Tree , asoft:Cover_Log ;
    asoft:isAdjacentTo asoft:ObjectiveZone_OutdoorWoods .

###  https://github.com/cdcc-jpg/ontologies#ObjectiveZone_OutdoorWoods
asoft:ObjectiveZone_OutdoorWoods rdf:type owl:NamedIndividual, asoft:ObjectiveArea ;
    rdfs:label "Outdoor Woods Objective"@en ;
    asoft:hasObstacle asoft:Cover_Bush ;
    asoft:isAdjacentTo asoft:SpawnZone_OutdoorWoods , asoft:RestrictedArea_OutdoorWoods .

###  https://github.com/cdcc-jpg/ontologies#RestrictedArea_OutdoorWoods
asoft:RestrictedArea_OutdoorWoods rdf:type owl:NamedIndividual, asoft:RestrictedArea ;
    rdfs:label "Outdoor Woods Restricted Area"@en ;
    asoft:hasAccessRestriction "No entry during play" .

###  https://github.com/cdcc-jpg/ontologies#SafetyZone_OutdoorWoods
asoft:SafetyZone_OutdoorWoods rdf:type owl:NamedIndividual, asoft:SafetyZone ;
    rdfs:label "Outdoor Woods Safety Zone"@en ;
    asoft:hasAccessRestriction "Weapon safety checks required" .

###  https://github.com/cdcc-jpg/ontologies#Entry_OutdoorWoods
asoft:Entry_OutdoorWoods rdf:type owl:NamedIndividual, asoft:EntryPoint ;
    rdfs:label "Outdoor Woods Entry"@en ;
    asoft:hasAccessRestriction "Gate access with valid player pass" .

###  https://github.com/cdcc-jpg/ontologies#Cover_Wall
asoft:Cover_Wall rdf:type owl:NamedIndividual, asoft:FieldObstacle ;
    rdfs:label "Cover wall"@en ;
    rdfs:comment "A fixed barrier used for cover in the field."@en .

###  https://github.com/cdcc-jpg/ontologies#Cover_Barrel
asoft:Cover_Barrel rdf:type owl:NamedIndividual, asoft:FieldObstacle ;
    rdfs:label "Cover barrel"@en ;
    rdfs:comment "A barrel or drum used as soft cover."@en .

###  https://github.com/cdcc-jpg/ontologies#Cover_Pillar
asoft:Cover_Pillar rdf:type owl:NamedIndividual, asoft:FieldObstacle ;
    rdfs:label "Cover pillar"@en ;
    rdfs:comment "A pillar structure used for concealment."@en .

###  https://github.com/cdcc-jpg/ontologies#Cover_Tree
asoft:Cover_Tree rdf:type owl:NamedIndividual, asoft:FieldObstacle ;
    rdfs:label "Cover tree"@en ;
    rdfs:comment "A natural tree used as cover in an outdoor field."@en .

###  https://github.com/cdcc-jpg/ontologies#Cover_Log
asoft:Cover_Log rdf:type owl:NamedIndividual, asoft:FieldObstacle ;
    rdfs:label "Cover log"@en ;
    rdfs:comment "A fallen log used as cover in an outdoor zone."@en .

###  https://github.com/cdcc-jpg/ontologies#Cover_Bush
asoft:Cover_Bush rdf:type owl:NamedIndividual, asoft:FieldObstacle ;
    rdfs:label "Cover bush"@en ;
    rdfs:comment "Bushes used as soft natural cover."@en .
