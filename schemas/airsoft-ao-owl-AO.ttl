@prefix : <https://github.com/cdcc-jpg/ontologies#> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix asoft: <https://github.com/cdcc-jpg/ontologies#> .
@prefix schema: <http://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://github.com/cdcc-jpg/ontologies#> .

<https://github.com/cdcc-jpg/ontologies#> rdf:type owl:Ontology ;
                                           dcterms:created "2024-05-20"^^xsd:date ;
                                           dcterms:creator "clement.dhollande@leurn.co" ;
                                           dcterms:description "A comprehensive ontology covering airsoft replicas, gear, and game rules." ;
                                           dcterms:title "An Airsoft Ontology" ;
                                           owl:versionInfo "2.11.0"^^xsd:string .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
dcterms:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000051
obo:BFO_0000051 rdf:type owl:ObjectProperty .


###  https://github.com/cdcc-jpg/ontologies#belongsToTeam
asoft:belongsToTeam rdf:type owl:ObjectProperty ;
                    rdfs:domain asoft:AirsoftPlayer ;
                    rdfs:range asoft:AirsoftTeam ;
                    rdfs:label "belongs to team"@en .


###  https://github.com/cdcc-jpg/ontologies#enforcesRule
asoft:enforcesRule rdf:type owl:ObjectProperty ;
                   rdfs:domain asoft:AirsoftMarshall ;
                   rdfs:range asoft:AirsoftRule ;
                   rdfs:label "enforces rule"@en .


###  https://github.com/cdcc-jpg/ontologies#hasPhases
asoft:hasPhases rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf obo:BFO_0000051 ;
                rdfs:domain asoft:StandardAirsoftSchedule ;
                rdfs:range rdf:List ;
                rdfs:label "has phases"@en .


###  https://github.com/cdcc-jpg/ontologies#isKilledBy
asoft:isKilledBy rdf:type owl:ObjectProperty ;
                 owl:inverseOf asoft:kills ;
                 rdfs:domain asoft:AirsoftPlayer ;
                 rdfs:range asoft:AirsoftPlayer .


###  https://github.com/cdcc-jpg/ontologies#kills
asoft:kills rdf:type owl:ObjectProperty ;
            rdfs:domain asoft:AirsoftPlayer ;
            rdfs:range asoft:AirsoftPlayer .


###  https://github.com/cdcc-jpg/ontologies#playsOnField
asoft:playsOnField rdf:type owl:ObjectProperty ;
                   rdfs:domain asoft:AirsoftPlayer ;
                   rdfs:range asoft:AirsoftField ;
                   rdfs:label "plays on field"@en .


###  https://github.com/cdcc-jpg/ontologies#usesGear
asoft:usesGear rdf:type owl:ObjectProperty ;
               rdfs:domain asoft:AirsoftPlayer ;
               rdfs:range asoft:AirsoftGear ;
               rdfs:label "uses gear"@en .


#################################################################
#    Data properties
#################################################################

###  https://github.com/cdcc-jpg/ontologies#hasAmmunitionCapacity
asoft:hasAmmunitionCapacity rdf:type owl:DatatypeProperty ;
                            rdfs:domain asoft:AirsoftReplica ;
                            rdfs:range xsd:integer ;
                            rdfs:label "has ammunition capacity"@en .


###  https://github.com/cdcc-jpg/ontologies#hasDecibel
asoft:hasDecibel rdf:type owl:DatatypeProperty .


###  https://github.com/cdcc-jpg/ontologies#hasDimension
asoft:hasDimension rdf:type owl:DatatypeProperty ;
                   rdfs:domain asoft:ShootingWindow .


###  https://github.com/cdcc-jpg/ontologies#hasFPS
asoft:hasFPS rdf:type owl:DatatypeProperty ;
             rdfs:domain asoft:AirsoftReplica ;
             rdfs:range xsd:integer ;
             rdfs:comment "Feet per second measurement of the replica."@en ;
             rdfs:label "has FPS"@en .


###  https://github.com/cdcc-jpg/ontologies#hasPowerLimit
asoft:hasPowerLimit rdf:type owl:DatatypeProperty ;
                    rdfs:domain asoft:AirsoftReplica ;
                    rdfs:range xsd:decimal ;
                    rdfs:label "has power limit"@en .


###  https://github.com/cdcc-jpg/ontologies#hasWeight
asoft:hasWeight rdf:type owl:DatatypeProperty ;
                rdfs:domain asoft:AirsoftGear ;
                rdfs:range xsd:decimal ;
                rdfs:comment "The physical weight of an object, usually measured in grams for airsoft."@en ;
                rdfs:label "has weight"@en .


#################################################################
#    Classes
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000015
obo:BFO_0000015 rdf:type owl:Class .


###  http://schema.org/Place
schema:Place rdf:type owl:Class .


###  http://schema.org/Product
schema:Product rdf:type owl:Class .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#List
rdf:List rdf:type owl:Class .


###  http://xmlns.com/foaf/0.1/Agent
foaf:Agent rdf:type owl:Class .


###  http://xmlns.com/foaf/0.1/Group
foaf:Group rdf:type owl:Class .


###  http://xmlns.com/foaf/0.1/Person
foaf:Person rdf:type owl:Class .


###  https://github.com/cdcc-jpg/ontologies#AirsoftAgent
asoft:AirsoftAgent rdf:type owl:Class ;
                   rdfs:subClassOf foaf:Agent ;
                   rdfs:comment "A type of agent that participates in an airsoft game." ;
                   rdfs:label "Airsoft agent"@en .


###  https://github.com/cdcc-jpg/ontologies#AirsoftBB
asoft:AirsoftBB rdf:type owl:Class ;
                rdfs:subClassOf asoft:AirsoftConsumable ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty asoft:hasWeight ;
                                  owl:hasValue 0.6
                                ] ;
                rdfs:comment "Spherical plastic or biodegradable projectiles fired by replicas."@en ;
                rdfs:label "Airsoft BB"@en .


###  https://github.com/cdcc-jpg/ontologies#AirsoftClothing
asoft:AirsoftClothing rdf:type owl:Class ;
                      rdfs:subClassOf asoft:AirsoftGear ;
                      rdfs:comment "A piece of gear worn on the body by the player."@en ;
                      rdfs:label "Airsoft Clothing"@en ,
                                 "Airsoft vest"@en .


###  https://github.com/cdcc-jpg/ontologies#AirsoftConsumable
asoft:AirsoftConsumable rdf:type owl:Class ;
                        rdfs:subClassOf asoft:AirsoftGear ;
                        rdfs:comment "A piece of consumable that allows physical interaction between players."@en ;
                        rdfs:label "Airsoft consumable"@en .


###  https://github.com/cdcc-jpg/ontologies#AirsoftField
asoft:AirsoftField rdf:type owl:Class ;
                   rdfs:subClassOf schema:Place ;
                   rdfs:comment "A place where airsoft is played."@en ;
                   rdfs:label "Airsoft field"@en .


###  https://github.com/cdcc-jpg/ontologies#AirsoftGame
asoft:AirsoftGame rdf:type owl:Class .


###  https://github.com/cdcc-jpg/ontologies#AirsoftGear
asoft:AirsoftGear rdf:type owl:Class ;
                  rdfs:subClassOf schema:Product ;
                  rdfs:comment "A type of object specifically used to play airsoft."@en ;
                  rdfs:label "Airsoft gear"@en .


###  https://github.com/cdcc-jpg/ontologies#AirsoftGrenade
asoft:AirsoftGrenade rdf:type owl:Class ;
                     rdfs:subClassOf asoft:AirsoftConsumable ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty asoft:hasDecibel ;
                                       owl:hasValue 120
                                     ] ;
                     rdfs:comment "A type of airsoft consumable that simulates the effect of a real grenade."@en ;
                     rdfs:label "Airsoft grenade"@en .


###  https://github.com/cdcc-jpg/ontologies#AirsoftManager
asoft:AirsoftManager rdf:type owl:Class ;
                     rdfs:subClassOf foaf:Person ,
                                     asoft:AirsoftAgent ;
                     rdfs:comment "A type of airsoft agent that organises an airsoft game." ;
                     rdfs:label "Airsoft Manager"@en .


###  https://github.com/cdcc-jpg/ontologies#AirsoftMarshall
asoft:AirsoftMarshall rdf:type owl:Class ;
                      rdfs:subClassOf foaf:Person ,
                                      asoft:AirsoftAgent ;
                      rdfs:comment "A type of airsoft agent that enforces airsoft rules during an airsoft game." ;
                      rdfs:label "Airsoft marshall"@en .


###  https://github.com/cdcc-jpg/ontologies#AirsoftPlayer
asoft:AirsoftPlayer rdf:type owl:Class ;
                    rdfs:subClassOf foaf:Person ,
                                    asoft:AirsoftAgent ;
                    rdfs:comment "A type of airsoft agent that plays an airsoft game." ;
                    rdfs:label "Airsoft player"@en .


###  https://github.com/cdcc-jpg/ontologies#AirsoftReplica
asoft:AirsoftReplica rdf:type owl:Class ;
                     rdfs:subClassOf asoft:AirsoftGear ;
                     rdfs:comment "A piece of gear that propels 0.6 polymer ballbearings (BBs)."@en ;
                     rdfs:label "Airsoft replica"@en .


###  https://github.com/cdcc-jpg/ontologies#AirsoftRule
asoft:AirsoftRule rdf:type owl:Class ;
                  rdfs:comment "A type of pre-established rules specifically applied to play airsoft."@en ;
                  rdfs:label "Airsoft rule"@en .


###  https://github.com/cdcc-jpg/ontologies#AirsoftTeam
asoft:AirsoftTeam rdf:type owl:Class ;
                  rdfs:subClassOf foaf:Group ,
                                  asoft:AirsoftAgent ;
                  rdfs:comment "An organized group of airsoft players."@en ;
                  rdfs:label "Airsoft Team"@en .


###  https://github.com/cdcc-jpg/ontologies#Briefing
asoft:Briefing rdf:type owl:Class ;
               rdfs:subClassOf obo:BFO_0000015 ;
               rdfs:label "Briefing"@en .


###  https://github.com/cdcc-jpg/ontologies#ElectricReplica
asoft:ElectricReplica rdf:type owl:Class ;
                      rdfs:subClassOf asoft:AirsoftReplica ;
                      rdfs:comment "A type of airsoft replica that uses an electric motor that compresses ambient air to propel BBs."@en ;
                      rdfs:label "Electric replica"@en .


###  https://github.com/cdcc-jpg/ontologies#EyeProtection
asoft:EyeProtection rdf:type owl:Class ;
                    rdfs:subClassOf asoft:AirsoftClothing ;
                    rdfs:comment "Mandatory safety glasses, goggles, or masks worn to protect the eyes from BBs."@en ;
                    rdfs:label "Eye Protection"@en .


###  https://github.com/cdcc-jpg/ontologies#GameEnd
asoft:GameEnd rdf:type owl:Class ;
              rdfs:subClassOf obo:BFO_0000015 ;
              rdfs:label "Game End"@en .


###  https://github.com/cdcc-jpg/ontologies#GameStart
asoft:GameStart rdf:type owl:Class ;
                rdfs:subClassOf obo:BFO_0000015 ;
                rdfs:label "Game Start"@en .


###  https://github.com/cdcc-jpg/ontologies#GbbrReplica
asoft:GbbrReplica rdf:type owl:Class ;
                  rdfs:subClassOf asoft:AirsoftReplica ;
                  rdfs:comment "A type of airsoft replica that uses compressed gas in magazines to propel BBs."@en ;
                  rdfs:label "GBBR replica"@en .


###  https://github.com/cdcc-jpg/ontologies#HpaReplica
asoft:HpaReplica rdf:type owl:Class ;
                 rdfs:subClassOf asoft:AirsoftReplica ;
                 rdfs:comment "A type of airsoft replica that uses a compress air tank to propel BBs."@en ;
                 rdfs:label "HPA replica"@en .


###  https://github.com/cdcc-jpg/ontologies#IndoorAirsoftField
asoft:IndoorAirsoftField rdf:type owl:Class ;
                         rdfs:subClassOf asoft:AirsoftField ;
                         rdfs:comment "A place located indoor where airsoft is played."@en ;
                         rdfs:label "Indoor airsoft field"@en .


###  https://github.com/cdcc-jpg/ontologies#Kill
asoft:Kill rdf:type owl:Class ;
           rdfs:subClassOf asoft:AirsoftRule ;
           rdfs:comment "The rule that states that a player is not allowed to interact with other players."@en ;
           rdfs:label "Kill"@en .


###  https://github.com/cdcc-jpg/ontologies#LunchBreak
asoft:LunchBreak rdf:type owl:Class ;
                 rdfs:subClassOf obo:BFO_0000015 ;
                 rdfs:label "Lunch Break"@en .


###  https://github.com/cdcc-jpg/ontologies#NoiseLimit
asoft:NoiseLimit rdf:type owl:Class ;
                 rdfs:subClassOf asoft:AirsoftRule ;
                 rdfs:comment "The rule that imposes a maximum sonic power limit emitted by consummables."@en ;
                 rdfs:label "Noise limit"@en .


###  https://github.com/cdcc-jpg/ontologies#OutdoorAirsoftField
asoft:OutdoorAirsoftField rdf:type owl:Class ;
                          rdfs:subClassOf asoft:AirsoftField ;
                          rdfs:comment "A place located outdoor where airsoft is played."@en ;
                          rdfs:label "Outdoor airsoft field"@en .


###  https://github.com/cdcc-jpg/ontologies#PowerLimit
asoft:PowerLimit rdf:type owl:Class ;
                 rdfs:subClassOf asoft:AirsoftRule ;
                 rdfs:comment "The rule that imposes a maximum cinetic power limit applied to polymer BBs."@en ;
                 rdfs:label "Power limit"@en .


###  https://github.com/cdcc-jpg/ontologies#ShootingWindow
asoft:ShootingWindow rdf:type owl:Class ;
                     rdfs:subClassOf asoft:AirsoftRule .


###  https://github.com/cdcc-jpg/ontologies#StandardAirsoftSchedule
asoft:StandardAirsoftSchedule rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  https://github.com/cdcc-jpg/ontologies#Field_CQBCity
asoft:Field_CQBCity rdf:type owl:NamedIndividual ,
                             asoft:IndoorAirsoftField ;
                    rdfs:label "CQB City Indoor Arena"@en .


###  https://github.com/cdcc-jpg/ontologies#MinimumShootingWindowSize
asoft:MinimumShootingWindowSize rdf:type owl:NamedIndividual ,
                                         asoft:ShootingWindow ;
                                asoft:hasDimension 400 .


###  https://github.com/cdcc-jpg/ontologies#Player_JohnDoe
asoft:Player_JohnDoe rdf:type owl:NamedIndividual ,
                              asoft:AirsoftPlayer ;
                     asoft:belongsToTeam asoft:Team_GhostSquad ;
                     asoft:playsOnField asoft:Field_CQBCity ;
                     asoft:usesGear asoft:Replica_CustomM4 ;
                     rdfs:label "John Doe"@en .


###  https://github.com/cdcc-jpg/ontologies#Replica_CustomM4
asoft:Replica_CustomM4 rdf:type owl:NamedIndividual ,
                                asoft:ElectricReplica ;
                       asoft:hasAmmunitionCapacity 120 ;
                       asoft:hasFPS 350 ;
                       rdfs:label "Custom M4A1 AEG"@en .


###  https://github.com/cdcc-jpg/ontologies#StandardAirsoftSchedule
asoft:StandardAirsoftSchedule rdf:type owl:NamedIndividual ,
                                       obo:BFO_0000015 ;
                              asoft:hasPhases [ ] .


###  https://github.com/cdcc-jpg/ontologies#Team_GhostSquad
asoft:Team_GhostSquad rdf:type owl:NamedIndividual ,
                               asoft:AirsoftTeam ;
                      rdfs:comment "A competitive CQB airsoft team."@en ;
                      rdfs:label "Ghost Squad"@en .


#################################################################
#    Annotations
#################################################################

asoft:StandardAirsoftSchedule rdfs:comment "The ordered sequence of a standard game day." .


###  Generated by the OWL API (version 4.5.29.2024-05-13T12:11:03Z) https://github.com/owlcs/owlapi
